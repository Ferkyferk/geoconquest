# ════════════════════════════════════════════════════════════════════
#  GeoConquest — Environment Variables
#  Copy this file to .env.local for local development.
#  Never commit .env.local or any file containing real secrets.
# ════════════════════════════════════════════════════════════════════

# ── NextAuth.js ──────────────────────────────────────────────────────────────

# Full public URL of your deployment (no trailing slash).
# Local:      http://localhost:3000
# Production: https://your-app.vercel.app  (or your custom domain)
NEXTAUTH_URL=http://localhost:3000

# Secret used to sign/encrypt session tokens and JWTs.
# Generate a strong value with: openssl rand -base64 32
# Any string works in dev, but use a strong random value in production.
NEXTAUTH_SECRET=replace-me-with-openssl-rand-base64-32

# ── Google OAuth ─────────────────────────────────────────────────────────────

# Create OAuth 2.0 credentials at:
#   https://console.cloud.google.com/apis/credentials
#
# When creating the credential, set these Authorized Redirect URIs:
#   Local:      http://localhost:3000/api/auth/callback/google
#   Production: https://your-app.vercel.app/api/auth/callback/google
GOOGLE_CLIENT_ID=your-client-id.apps.googleusercontent.com
GOOGLE_CLIENT_SECRET=your-client-secret

# ── Database (PostgreSQL) ─────────────────────────────────────────────────────

# PostgreSQL connection string. Supported providers:
#
# Option A — Local PostgreSQL (Docker):
#   docker run --name geoconquest-db \
#     -e POSTGRES_USER=postgres \
#     -e POSTGRES_PASSWORD=postgres \
#     -e POSTGRES_DB=geoconquest \
#     -p 5432:5432 -d postgres:16
#
#   DATABASE_URL="postgresql://postgres:postgres@localhost:5432/geoconquest"
#
# Option B — Neon (free tier, recommended for dev & production):
#   https://neon.tech → New project → copy the connection string
#   DATABASE_URL="postgresql://user:password@ep-xxx.us-east-1.aws.neon.tech/geoconquest?sslmode=require"
#
# Option C — Supabase (free tier):
#   https://supabase.com → Project Settings → Database
#   Use the "Connection string (URI)" — switch to the "Transaction" pooler
#   for serverless (Vercel), and set DIRECT_DATABASE_URL to the direct URI.
#   DATABASE_URL="postgresql://postgres.[ref]:[password]@aws-0-us-east-1.pooler.supabase.com:6543/postgres"
#
# Option D — Vercel Postgres:
#   Vercel Dashboard → Storage → Create Database → Postgres
#   Vercel injects POSTGRES_URL automatically; just map it:
#   DATABASE_URL=$POSTGRES_URL
#
DATABASE_URL="postgresql://postgres:postgres@localhost:5432/geoconquest"

# ── Optional: Direct Database URL ────────────────────────────────────────────

# Required only when DATABASE_URL points to a connection pooler (pgBouncer,
# Neon pooled, Supabase Transaction pooler). Prisma uses this URL for
# migrations which require a direct (non-pooled) connection.
#
# If you're using a direct connection or Vercel Postgres, leave this unset.
# If you uncomment this, also add `directUrl = env("DIRECT_DATABASE_URL")`
# to the `datasource db` block in prisma/schema.prisma.
#
# For local dev with a direct connection, this can match DATABASE_URL.
# For Neon/Supabase pooled connections, set this to the direct (non-pooled) URL.
DIRECT_DATABASE_URL="postgresql://postgres:postgres@localhost:5432/geoconquest"
